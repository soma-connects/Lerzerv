# Lezerv Production Environment Variables
# Copy this file to .env and fill in the values

# API Base URL (AWS API Gateway or Amplify Endpoint)
VITE_API_URL=https://api.lezerv.com/v1

# AWS Configuration (If using AWS SDK directly)
VITE_AWS_REGION=eu-west-1
VITE_AWS_USER_POOL_ID=
VITE_AWS_CLIENT_ID=

# Analytics
VITE_GA_MEASUREMENT_ID=
