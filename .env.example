# Lezerv Environment Variables
# Copy this file to .env and fill in the values. NEVER commit .env.
#
# NOTE: Only VITE_-prefixed vars are exposed to the browser. Put ONLY public,
# non-secret values here. Secret keys (Paystack secret key, Supabase service-role
# key, SMS provider keys) must live in Supabase Edge Function secrets / server env,
# NEVER in this file.

# ── Supabase (required) ─────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Payments: Paystack (public key only — client side) ──────
# Secret key goes in Supabase Edge Function secrets, not here.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Analytics (optional) ────────────────────────────────────
VITE_GA_MEASUREMENT_ID=
